# Auto detect text files and normalize line endings to LF
* text=auto

# TypeScript
*.ts text eol=lf

# JavaScript
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# JSON
*.json text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
