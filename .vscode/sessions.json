{
  "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v11/terminal-keeper.json",
  "theme": "tribe",
  "active": "navigation",
  "activateOnStartup": true,
  "keepExistingTerminals": false,
  "sessions": {
    "navigation": [
      {
        "name": "root",
        "autoExecuteCommands": true,
        "icon": "folder",
        "color": "terminal.ansiWhite",
        "commands": ["ls -F"],
        "joinOperator": ";"
      }
    ],
    "tasks": [
      {
        "name": "install",
        "autoExecuteCommands": true,
        "icon": "package",
        "color": "terminal.ansiMagenta",
        "commands": ["npm ci", "npm --prefix apps/visualizer ci", "npm --prefix docs ci"],
        "joinOperator": ";"
      },
      {
        "name": "build",
        "autoExecuteCommands": true,
        "icon": "tools",
        "color": "terminal.ansiBlue",
        "commands": ["npm run build"],
        "joinOperator": ";"
      },
      {
        "name": "pr-checklist",
        "autoExecuteCommands": true,
        "icon": "checklist",
        "color": "terminal.ansiGreen",
        "commands": [
          "npm run format",
          "npm run visualizer:install",
          "npm run docs:install",
          "npm run build",
          "npm run docs:build",
          "npm run test:run"
        ],
        "joinOperator": ";"
      }
    ],
    "dev": [
      {
        "name": "app:watch",
        "autoExecuteCommands": true,
        "icon": "eye",
        "color": "terminal.ansiCyan",
        "commands": ["npm run dev"],
        "joinOperator": ";"
      },
      {
        "name": "docs:watch",
        "autoExecuteCommands": true,
        "icon": "book",
        "color": "terminal.ansiCyan",
        "commands": ["npm run docs"],
        "joinOperator": ";"
      },
      {
        "name": "visualizer:watch",
        "autoExecuteCommands": true,
        "icon": "browser",
        "color": "terminal.ansiCyan",
        "commands": ["npm run visualizer:dev"],
        "joinOperator": ";"
      }
    ],
    "build": [
      {
        "name": "app:build",
        "autoExecuteCommands": true,
        "icon": "tools",
        "color": "terminal.ansiBlue",
        "commands": ["npm run build"],
        "joinOperator": ";"
      },
      {
        "name": "docs:build",
        "autoExecuteCommands": true,
        "icon": "cloud-upload",
        "color": "terminal.ansiBlue",
        "commands": ["npm run docs:build"],
        "joinOperator": ";"
      },
      {
        "name": "visualizer:build",
        "autoExecuteCommands": true,
        "icon": "browser",
        "color": "terminal.ansiBlue",
        "commands": ["npm run visualizer:build"],
        "joinOperator": ";"
      }
    ],
    "type": [
      {
        "name": "type:check",
        "autoExecuteCommands": true,
        "icon": "checklist",
        "color": "terminal.ansiYellow",
        "commands": ["npm run type:check"],
        "joinOperator": ";"
      }
    ],
    "lint": [
      {
        "name": "lint:check",
        "autoExecuteCommands": true,
        "icon": "error",
        "color": "terminal.ansiRed",
        "commands": ["npm run lint:check"],
        "joinOperator": ";"
      },
      {
        "name": "lint:fix",
        "autoExecuteCommands": true,
        "icon": "wrench",
        "color": "terminal.ansiBlue",
        "commands": ["npm run lint:fix"],
        "joinOperator": ";"
      },
      {
        "name": "format:check",
        "autoExecuteCommands": true,
        "icon": "layout",
        "color": "terminal.ansiGreen",
        "commands": ["npm run format:check"],
        "joinOperator": ";"
      },
      {
        "name": "format:fix",
        "autoExecuteCommands": true,
        "icon": "zap",
        "color": "terminal.ansiGreen",
        "commands": ["npm run format"],
        "joinOperator": ";"
      }
    ],
    "test": [
      {
        "name": "test:watch",
        "autoExecuteCommands": true,
        "icon": "test-view-icon",
        "color": "terminal.ansiMagenta",
        "commands": ["npm run test:watch"],
        "joinOperator": ";"
      },
      {
        "name": "test:all",
        "autoExecuteCommands": true,
        "icon": "beaker",
        "color": "terminal.ansiYellow",
        "commands": ["npm test"],
        "joinOperator": ";"
      },
      {
        "name": "test:unit",
        "autoExecuteCommands": true,
        "icon": "pulse",
        "color": "terminal.ansiCyan",
        "commands": ["npm run test:unit"],
        "joinOperator": ";"
      },
      {
        "name": "test:integration",
        "autoExecuteCommands": true,
        "icon": "git-compare",
        "color": "terminal.ansiBlue",
        "commands": ["npm run test:integration"],
        "joinOperator": ";"
      },
      {
        "name": "test:validation",
        "autoExecuteCommands": true,
        "icon": "pass",
        "color": "terminal.ansiGreen",
        "commands": ["npm run test:validation"],
        "joinOperator": ";"
      },
      {
        "name": "test:coverage",
        "autoExecuteCommands": true,
        "icon": "shield",
        "color": "terminal.ansiMagenta",
        "commands": ["npm run test:coverage"],
        "joinOperator": ";"
      },
      {
        "name": "coverage:open",
        "autoExecuteCommands": true,
        "icon": "browser",
        "color": "terminal.ansiCyan",
        "commands": ["npm run coverage:open"],
        "joinOperator": ";"
      }
    ],
    "release": [
      {
        "name": "changelog:regenerate",
        "autoExecuteCommands": true,
        "icon": "list-unordered",
        "color": "terminal.ansiCyan",
        "commands": ["npm run changelog"],
        "joinOperator": ";"
      },
      {
        "name": "release:notes:latest",
        "autoExecuteCommands": true,
        "icon": "note",
        "color": "terminal.ansiCyan",
        "commands": [
          "node scripts/release.mjs release-notes \"$(git tag --sort=version:refname | tail -n 1)\""
        ],
        "joinOperator": ";"
      },
      {
        "name": "release:list",
        "autoExecuteCommands": true,
        "icon": "tag",
        "color": "terminal.ansiCyan",
        "commands": ["gh release list"],
        "joinOperator": ";"
      },
      {
        "name": "release:patch",
        "autoExecuteCommands": true,
        "icon": "tag",
        "color": "terminal.ansiGreen",
        "commands": ["npm run release -- patch"],
        "joinOperator": ";"
      },
      {
        "name": "release:minor",
        "autoExecuteCommands": true,
        "icon": "tag",
        "color": "terminal.ansiYellow",
        "commands": ["npm run release -- minor"],
        "joinOperator": ";"
      },
      {
        "name": "release:major",
        "autoExecuteCommands": true,
        "icon": "tag",
        "color": "terminal.ansiRed",
        "commands": ["npm run release -- major"],
        "joinOperator": ";"
      },
      {
        "name": "release:push",
        "autoExecuteCommands": false,
        "icon": "cloud-upload",
        "color": "terminal.ansiRed",
        "commands": ["git push origin main --follow-tags"],
        "joinOperator": ";"
      }
    ]
  }
}
